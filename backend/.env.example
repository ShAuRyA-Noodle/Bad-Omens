# ─── backend/.env.example ────────────────────────────────────────────────
# Copy this file to backend/.env and fill in the real values.
# backend/.env is git-ignored. NEVER commit a file containing real secrets.

# ─── Core infrastructure ─────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=edna
POSTGRES_PASSWORD=change-me-in-local-dev
POSTGRES_DB=edna_insights

REDIS_HOST=redis
REDIS_PORT=6379

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-in-local-dev
MINIO_BUCKET=relict
MINIO_SECURE=false

# ─── Application security ───────────────────────────────────────────────
JWT_SECRET=generate-a-long-random-string-and-paste-it-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# ─── External APIs ──────────────────────────────────────────────────────
# IUCN Red List — https://api.iucnredlist.org/users/edit
IUCN_REDLIST_TOKEN=

# GBIF — https://www.gbif.org/user/profile
GBIF_USERNAME=
GBIF_PASSWORD=
GBIF_EMAIL=

# NCBI Entrez — https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_EMAIL=

# ─── Optional ───────────────────────────────────────────────────────────
ZENODO_SANDBOX_TOKEN=
ANTHROPIC_API_KEY=

# ─── Docker host port mappings ──────────────────────────────────────────
# Change these if any of the defaults clash with something on your machine.
# (e.g. set API_HOST_PORT=18000 if 8000 is already in use locally.)
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
ADMINER_HOST_PORT=8081   # shifted off 8080 so it doesn't clash with Vite dev

# ─── Runtime ────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
